# ╔══════════════════════════════════════════════════╗
# ║        КОНФИГУРАЦИЯ ТГ АССИСТЕНТА                ║
# ║  Скопируй этот файл как .env и заполни           ║
# ╚══════════════════════════════════════════════════╝

# ──────────────────────────────────────────────────────
# TELEGRAM (получить на https://my.telegram.org/apps)
# ──────────────────────────────────────────────────────

# ID приложения (число)
TG_API_ID=12345678

# Hash приложения (строка)
TG_API_HASH=abcdef1234567890abcdef1234567890

# Номер телефона АККАУНТА-АССИСТЕНТА (с кодом страны)
# Это отдельный аккаунт, НЕ твой основной!
TG_PHONE=+79991234567

# Твой личный Telegram ID (числовой)
# Узнать можно у бота @userinfobot
TG_OWNER_ID=123456789

# Username аккаунта-ассистента (без @, для логов)
TG_ASSISTANT_USERNAME=my_assistant_bot

# ──────────────────────────────────────────────────────
# LM STUDIO
# ──────────────────────────────────────────────────────

# URL локального сервера LM Studio (по умолчанию)
LM_STUDIO_URL=http://localhost:1234/v1

# Название модели (оставь пустым — выберет первую загруженную)
LM_MODEL=

# Максимум токенов в ответе
LM_MAX_TOKENS=1024

# Температура (0.0 = детерминированный, 1.0 = творческий)
LM_TEMPERATURE=0.7

# Таймаут ожидания ответа (секунды)
LM_TIMEOUT=120

# ──────────────────────────────────────────────────────
# СИСТЕМНЫЙ ПРОМПТ (опционально, переопределяет дефолтный)
# ──────────────────────────────────────────────────────
# SYSTEM_PROMPT=Ты мой личный ассистент. Отвечай кратко и по делу.

# ──────────────────────────────────────────────────────
# ПУТИ К ФАЙЛАМ (менять не обязательно)
# ──────────────────────────────────────────────────────
TEMPLATES_FILE=config/templates.json
SESSION_FILE=sessions/assistant

# ──────────────────────────────────────────────────────
# МОНИТОРИНГ — ЛОГИРОВАНИЕ СООБЩЕНИЙ
# ──────────────────────────────────────────────────────

# Каналы/чаты куда скидывать ВСЕ входящие сообщения (через запятую)
# Можно указать несколько: числовой ID канала или @username
#
# Как получить ID канала:
#   1. Перешли любое сообщение из канала боту @userinfobot
#   2. Он покажет ID вида -1001234567890
#
# Примеры:
# LOG_CHANNELS=-1001234567890
# LOG_CHANNELS=-1001234567890,@my_private_log
# LOG_CHANNELS=@limina_logs
LOG_CHANNELS=-1003807073500
